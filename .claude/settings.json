{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); echo \"$FILE\" | grep -qE '\\.tf$' && terraform fmt \"$FILE\" 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"Add-Type -AssemblyName System.Windows.Forms; $n = New-Object System.Windows.Forms.NotifyIcon; $n.Icon = [System.Drawing.SystemIcons]::Information; $n.Visible = $true; $n.ShowBalloonTip(3000, 'Claude Code', 'Needs your attention', 'Info'); Start-Sleep 4; $n.Dispose()\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(/**)",
      "Bash(terraform:*)",
      "Bash(terragrunt:*)",
      "Bash(git:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(xargs:*)",
      "Bash(wc:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(gh:*)",
      "Bash(az:*)",
      "Bash(curl:*)",
      "WebFetch(domain:registry.terraform.io)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:microsoft.github.io)"
    ],
    "deny": []
  }
}
